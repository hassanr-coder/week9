#This assignment is the same as Assignment 1, with requirements for assignment 2 like added error handling for file operations.
def read_file():
    filename = input("Enter the name of the file to read: ")
    try: 
        with open (filename,'r') as f:
            content= f.read()
            print("\n--- File Content ---")
            print(content)
            print ("--------------------")
    except FileNotFoundError:
        print("Error: File not found.\n")

def create_new_file():
    filename = input("Enter the name of the new file to create: ")
    content = input("Enter the content to write to the file: ")
    
    with open (filename,'w') as f:
        f.write(content)

    print(f"File '{filename}' created successfully.\n")

def append_to_file():
    filename = input("Enter the name of the file to append to: ")
    content = input("Enter the content to append to the file: ")
    
    try:
        with open (filename,'a') as f:
            f.write ("\n" + content)
            print(f"Text appended to '{filename}' successfully.\n")
    except FileNotFoundError:
        print("Error: File not found.\n")   

#Program Starts Here
while True:
    print("Choose an option:")
    print("1. Read a file")
    print("2. Create a new file")
    print("3. Append to a file")
    print("4. Exit")
    
    choice = input("Enter your choice (1-4): ")
    
    if choice == "1":
        read_file()
    elif choice == "2":
        create_new_file()
    elif choice == "3":
        append_to_file()
    elif choice == "4":
        print("Exiting...")
        break
    else:
        print("Invalid choice. Try again.\n")